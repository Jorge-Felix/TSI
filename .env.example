# Obligatorio: clave de Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude (claude-sonnet-4-6 es el reemplazo del deprecado claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
API_TIMEOUT_SECONDS=120

# Fuente principal gratuita: API key de VirusTotal v3 (https://www.virustotal.com)
# Free tier: 4 req/min, ~500 req/día
VIRUSTOTAL_API_KEY=

# Opcional: token gratuito de tria.ge (cuenta Researcher)
TRIAGE_API_TOKEN=

# Fuente por defecto: virustotal | triage | any_run | fixture
DEFAULT_SOURCE=fixture

# Directorio de salida
OUTPUT_DIR=./output

# DEBUG | INFO | WARNING
LOG_LEVEL=INFO
